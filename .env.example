# RDS DuckDB 连接配置
# 此文件包含敏感信息，已加入 .gitignore，不要上传到公开仓库

# DuckDB 连接配置
DUCKDB_HOST=rm-xxx.mysql.rds.aliyuncs.com
DUCKDB_PORT=your_port
DUCKDB_USER=your_username
DUCKDB_PASSWORD=your_password_here
DUCKDB_DATABASE=your_database

# 可选：RDS 实例 ID（用于验证实例类型）
RDS_INSTANCE_ID=rm-xxxx

# 可选：阿里云凭证（用于实例验证）
ALIYUN_REGION=cn-hangzhou
ALIYUN_ACCESS_KEY_ID=your_access_key
ALIYUN_ACCESS_KEY_SECRET=your_access_secret

# 持久化目录
RECORDS_DIR=/home/admin/.openclaw/workspace/skills/alibabacloud-rds-duckdb-analytics-skill/records
